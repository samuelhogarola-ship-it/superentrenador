{
  "name": "superentrenador-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run lint && npm run build",
    "ci": "npm test && npm run check",
    "prepare": "husky",
    "security:setup": "node scripts/install-gitleaks.mjs",
    "secrets:scan": ".tools/gitleaks/current/gitleaks git --redact --no-banner .",
    "secrets:scan:staged": ".tools/gitleaks/current/gitleaks git --staged --redact --no-banner .",
    "audit:deps": "audit-ci --config ./audit-ci.jsonc",
    "commitlint": "commitlint --from HEAD~1 --to HEAD"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.57.4",
    "date-fns": "^4.4.0",
    "lucide-react": "^0.552.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "audit-ci": "^7.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
